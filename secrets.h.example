#pragma once

// Copy this file to secrets.h and fill in your own values.
// secrets.h is gitignored so your credentials stay local.

#define WIFI_SSID "your-wifi-ssid"
#define WIFI_PASS "your-wifi-password"

#define TV_IP  "192.168.1.100"
#define TV_PSK "0000"

// TV MAC address for Wake-on-LAN (as 6 comma-separated bytes)
#define TV_MAC_BYTES   0x00, 0x00, 0x00, 0x00, 0x00, 0x00
// Subnet broadcast address used for the WoL magic packet
#define WOL_BROADCAST  "192.168.1.255"
